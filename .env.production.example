# ============================================================
# StorePilot — Production Environment Template
# Copy file này thành .env trên VPS, điền đầy đủ các giá trị
# KHÔNG commit file .env thật lên git
# ============================================================

# Database (trùng với POSTGRES_USER/PASSWORD/DB bên dưới)
DATABASE_URL="postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB"

# PostgreSQL
POSTGRES_USER="storepilot"
POSTGRES_PASSWORD="<mật khẩu mạnh, ít nhất 20 ký tự>"
POSTGRES_DB="storepilot"

# Redis — để trống nếu không dùng password (không khuyến khích)
REDIS_PASSWORD="<mật khẩu mạnh cho redis>"

# NextAuth — NEXTAUTH_URL phải là domain thật, NEXTAUTH_SECRET tối thiểu 32 ký tự
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="<generate: openssl rand -base64 32>"

# Encryption key — BẮT BUỘC đúng 64 ký tự hex (32 bytes)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="<generate: openssl rand -hex 32>"

# Cron secret — dùng cho scheduled tasks
CRON_SECRET="<generate: openssl rand -hex 24>"
