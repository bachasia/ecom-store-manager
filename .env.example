# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://pnl_user:pnl_password@localhost:5432/pnl_dashboard"

# For Docker, use service name as host:
# DATABASE_URL="postgresql://pnl_user:pnl_password@postgres:5432/pnl_dashboard"

# Production Database Credentials (for docker-compose.prod.yml)
POSTGRES_USER="pnl_user"
POSTGRES_PASSWORD="change-this-in-production"
POSTGRES_DB="pnl_dashboard"

# ==============================================
# NEXTAUTH CONFIGURATION
# ==============================================

# NextAuth URL - Your application URL
NEXTAUTH_URL="http://localhost:3000"

# NextAuth Secret - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ==============================================
# ENCRYPTION
# ==============================================

# Encryption Key for API credentials (32 bytes for AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-32-byte-hex-key-here"

# ==============================================
# REDIS (OPTIONAL - FOR CACHING)
# ==============================================

# Redis Connection String
REDIS_URL="redis://localhost:6379"

# For Docker with password:
# REDIS_URL="redis://:your-redis-password@redis:6379"

# Redis Password (for production)
REDIS_PASSWORD="change-this-in-production"

# ==============================================
# CRON JOBS
# ==============================================

# Secret for authenticating internal cron job requests (auto sync scheduler)
# Generate: openssl rand -hex 24
# Used by: GET /api/cron/sync (Authorization: Bearer <CRON_SECRET>)
#          POST /api/sync/orders/[storeId] (x-cron-internal header)
#          POST /api/sync/products/[storeId] (x-cron-internal header)
CRON_SECRET="generate-random-secret-for-cron"

# ==============================================
# OAUTH PROVIDERS (OPTIONAL)
# ==============================================

# Google OAuth (if using Google login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==============================================
# ERROR TRACKING (OPTIONAL)
# ==============================================

# Sentry DSN for error tracking
SENTRY_DSN="your-sentry-dsn-here"

# ==============================================
# APPLICATION SETTINGS
# ==============================================

# Node Environment
NODE_ENV="development"

# Next.js Telemetry
NEXT_TELEMETRY_DISABLED=1

# ==============================================
# SHOPBASE API (EXAMPLE)
# ==============================================
# These are stored per-store in the database
# This is just for reference/testing

# SHOPBASE_STORE_URL="https://your-store.onshopbase.com"
# SHOPBASE_API_KEY="your-api-key"

# ==============================================
# WOOCOMMERCE API (EXAMPLE)
# ==============================================
# These are stored per-store in the database
# This is just for reference/testing

# WOOCOMMERCE_STORE_URL="https://your-store.com"
# WOOCOMMERCE_CONSUMER_KEY="ck_xxxxx"
# WOOCOMMERCE_CONSUMER_SECRET="cs_xxxxx"

# ==============================================
# NOTES
# ==============================================
# 1. Copy this file to .env.local for development
# 2. Never commit .env.local to version control
# 3. Generate strong secrets for production
# 4. Update all "change-this-in-production" values
# 5. Store production secrets securely (e.g., in a password manager)
