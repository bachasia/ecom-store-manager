// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum SystemRole {
  SUPER_ADMIN
  USER
}

enum StoreRole {
  OWNER
  MANAGER
  VIEWER
  DATA_ENTRY
}

// User & Authentication
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  password      String     // hashed
  emailVerified DateTime?
  image         String?
  systemRole    SystemRole @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  stores        Store[]
  storeMembers  StoreUser[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Store Management
model Store {
  id          String   @id @default(cuid())
  userId      String
  name        String
  platform    String   // 'shopbase' | 'woocommerce'
  apiUrl      String   // Store URL
  apiKey      String   // Encrypted
  apiSecret     String?  // Encrypted (for WooCommerce)
  pluginSecret  String?  // Encrypted — shared secret with PNL Sync WordPress plugin
  isActive    Boolean  @default(true)
  currency    String   @default("USD")
  timezone    String   @default("UTC")
  
  lastSyncAt  DateTime?
  lastSyncStatus String? // 'success' | 'error' | 'in_progress'
  lastSyncError  String? @db.Text

  // Auto sync
  autoSyncEnabled       Boolean   @default(false)
  autoSyncInterval      Int       @default(60)    // phút, min=15
  lastOrderAutoSyncAt   DateTime?
  lastProductAutoSyncAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     StoreUser[]
  products    Product[]
  orders      Order[]
  adsCosts           AdsCost[]
  syncLogs           SyncLog[]
  adsAccountMappings AdsAccountMapping[]
  
  @@index([userId])
}

// Store Membership & Role
model StoreUser {
  id        String    @id @default(cuid())
  storeId   String
  userId    String
  role      StoreRole @default(VIEWER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([userId])
  @@index([storeId])
}

// Products & SKUs
model Product {
  id              String   @id @default(cuid())
  storeId         String
  externalId      String   // ID from platform (variant-level)
  parentExternalId String? // ID of parent product (product-level) — null for simple products
  name            String
  sku             String
  variantName     String?
  baseCost        Decimal  @default(0) @db.Decimal(10, 2) // COGS - manually set
  platformCost    Decimal? @db.Decimal(10, 2) // Cost from platform (if available)
  price           Decimal  @db.Decimal(10, 2)
  imageUrl        String?  // Product image from platform
  isActive        Boolean  @default(true)
  hasSkuWarning   Boolean  @default(false) // true nếu SKU được sinh tự động (không có SKU gốc từ platform)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  store           Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  costHistory     ProductCostHistory[]

  @@unique([storeId, externalId, sku])
  @@index([storeId])
  @@index([sku])
  @@index([storeId, parentExternalId])
  @@index([storeId, name])
  @@index([storeId, sku])
}

// COGS cost history — tracks price changes over time per product/variant
model ProductCostHistory {
  id            String   @id @default(cuid())
  productId     String
  cost          Decimal  @db.Decimal(10, 2)   // COGS effective from this date
  effectiveDate DateTime                       // first order date this cost applies to
  note          String?                        // optional reason (e.g. "vendor price increase Feb 2026")
  createdAt     DateTime @default(now())

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, effectiveDate])
}

// Orders
model Order {
  id                String   @id @default(cuid())
  storeId           String
  externalId        String   // Order ID from platform
  orderNumber       String
  orderDate         DateTime
  status            String   // 'pending', 'processing', 'completed', 'cancelled', 'refunded'
  
  // Customer Info
  customerEmail     String?
  customerName      String?
  customerCountry   String?
  billingAddress    String?  @db.Text
  shippingAddress   String?  @db.Text
  
  // Financial Data
  subtotal          Decimal  @db.Decimal(10, 2)
  discount          Decimal  @default(0) @db.Decimal(10, 2)
  shipping          Decimal  @default(0) @db.Decimal(10, 2)
  tax               Decimal  @default(0) @db.Decimal(10, 2)
  total             Decimal  @db.Decimal(10, 2) // Final order total
  refundAmount      Decimal  @default(0) @db.Decimal(10, 2)
  vendorRefundAmount Decimal @default(0) @db.Decimal(10, 2) // Nhà cung cấp hoàn lại → giảm chi phí, tăng profit
  
  // Payment Info
  paymentMethod     String?
  paymentGatewayId  String?
  transactionFee    Decimal  @default(0) @db.Decimal(10, 2) // Calculated
  
  // Marketing Attribution
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  
  // P&L Calculations (cached)
  totalCOGS         Decimal  @default(0) @db.Decimal(10, 2)
  allocatedAdsCost  Decimal  @default(0) @db.Decimal(10, 2)
  grossProfit       Decimal  @default(0) @db.Decimal(10, 2)
  netProfit         Decimal  @default(0) @db.Decimal(10, 2)
  profitMargin      Decimal  @default(0) @db.Decimal(5, 2) // Percentage
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  store             Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  paymentGateway    PaymentGateway? @relation(fields: [paymentGatewayId], references: [id])
  orderItems        OrderItem[]
  
  @@unique([storeId, externalId])
  @@index([storeId])
  @@index([orderDate])
  @@index([status])
  @@index([storeId, orderDate])         // report queries filter by store + date range
  @@index([storeId, status, orderDate]) // report queries filter by store + status + date
}

// Order Line Items
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  
  sku         String
  productName String
  quantity    Int
  price       Decimal @db.Decimal(10, 2) // Unit price
  total       Decimal @db.Decimal(10, 2) // quantity * price
  
  // Calculated
  unitCost    Decimal @default(0) @db.Decimal(10, 2) // From Product.baseCost
  totalCost   Decimal @default(0) @db.Decimal(10, 2) // unitCost * quantity
  
  createdAt   DateTime @default(now())
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
  @@index([sku])
}

// Advertising Costs
model AdsCost {
  id            String   @id @default(cuid())
  storeId       String
  date          DateTime @db.Date
  platform      String   // 'facebook' | 'google' | 'manual'

  accountName   String   @default("")  // Tên tài khoản ads (từ "Account name" trong CSV)
  campaignName  String   @default("")
  adsetName     String   @default("")

  // Currency
  currency        String   @default("USD")   // Currency gốc từ file CSV
  originalSpend   Decimal? @db.Decimal(10, 2) // Chi phí theo currency gốc (nếu khác USD)
  exchangeRate    Decimal? @db.Decimal(12, 6) // Tỷ giá đã dùng để convert sang USD
  spend           Decimal  @db.Decimal(10, 2) // Luôn là USD — dùng cho P&L

  // Standard metrics
  impressions   Int?
  clicks        Int?

  // Facebook Ads extended metrics
  ctr             Decimal? @db.Decimal(12, 8) // CTR (all) — %
  cpm             Decimal? @db.Decimal(10, 6) // Cost per 1,000 impressions
  purchases       Int?                         // Số lượt mua hàng
  costPerPurchase Decimal? @db.Decimal(10, 6) // Cost per purchase
  purchaseValue   Decimal? @db.Decimal(10, 2) // Purchases conversion value (revenue)
  cpc             Decimal? @db.Decimal(10, 8) // CPC (cost per link click)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, platform, accountName, campaignName, adsetName])
  @@index([storeId])
  @@index([date])
  @@index([storeId, date])
  @@index([accountName])
}

// Ads Account Mapping — map nhiều Ads Account vào 1 Store
model AdsAccountMapping {
  id          String   @id @default(cuid())
  storeId     String
  accountName String   // Tên account trong file CSV, VD: "VNEC 10", "HT 332702"
  platform    String   @default("facebook") // 'facebook' | 'google' | 'manual'
  description String?  // Ghi chú tùy chọn

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([platform, accountName])
  @@index([storeId])
}

// Payment Gateway Settings
model PaymentGateway {
  id              String  @id @default(cuid())
  name            String  @unique // 'stripe', 'paypal', 'square', etc.
  displayName     String
  matchKeywords   String? @db.Text // Comma-separated aliases: paypal,paypal-express
  feePercentage   Decimal @default(0) @db.Decimal(5, 2) // e.g., 2.9
  feeFixed        Decimal @default(0) @db.Decimal(10, 2) // e.g., 0.30
  isActive        Boolean @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  orders          Order[]
}

// Sync Logs
model SyncLog {
  id              String   @id @default(cuid())
  storeId         String
  syncType        String   // 'orders' | 'products'
  status          String   // 'started' | 'success' | 'error'
  recordsProcessed Int     @default(0)
  recordsCreated  Int      @default(0)
  recordsUpdated  Int      @default(0)
  errorMessage    String?  @db.Text
  
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@index([storeId])
  @@index([startedAt])
}

// App Settings
model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  
  updatedAt   DateTime @updatedAt
}
